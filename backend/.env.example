# Template Environment Configurations for Poiro AI Battle Room

# Groq LLM API Key (Provide a valid gsk_... key from console.groq.com)
GROQ_API_KEY=

# Set to true to utilize the zero-cost procedural fallback campaign copy engine
FORCE_MOCK_AI=true

# Database Persistence Setup
DATABASE_URL=sqlite:///./poiro_battle.db

# JWT Security Secrets (Replace with random hash in production)
JWT_SECRET=super_secret_cyberpunk_campaign_key_31337_!
